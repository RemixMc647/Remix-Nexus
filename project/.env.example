# Copy this file to ".env" and fill in your real values.
# Never commit your real ".env" file.

# --- MongoDB Atlas ---
# 1. Create a free cluster at https://www.mongodb.com/cloud/atlas
# 2. Create a database user + password
# 3. Get your connection string ("Connect" > "Drivers") and paste it here
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@your-cluster.mongodb.net/remixmc?retryWrites=true&w=majority

# --- Auth ---
# Any long random string. You can generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# --- Server ---
PORT=3000

# --- CORS (only needed if the frontend is hosted on a DIFFERENT domain
# than this backend; if everything is served from this same server/Render
# app, you can leave this as * or remove it) ---
FRONTEND_ORIGIN=*
